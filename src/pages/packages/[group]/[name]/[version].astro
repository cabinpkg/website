---
import PackageDetailView from "../../../../components/package/PackageDetailView.astro";
import {
    getPackageVersionHref,
    getPackageVersionStaticPaths,
    type PackageRecord,
} from "../../../../lib/packages";

interface Props {
    pack: PackageRecord;
    versionCount: number;
}

export async function getStaticPaths() {
    return getPackageVersionStaticPaths();
}

const { pack, versionCount } = Astro.props;
---

<PackageDetailView
    pack={pack}
    versionCount={versionCount}
    title={`${pack.name} (v${pack.version})`}
    description={pack.description ||
        `Cabin package ${pack.name} v${pack.version}`}
    canonicalPath={getPackageVersionHref(pack.name, pack.version)}
/>
