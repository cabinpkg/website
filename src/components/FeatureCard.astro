---
import GradientIcon from "./GradientIcon.astro";
import type { IconName } from "./Icon.astro";
import Card from "./ui/Card.astro";

interface Props {
    icon: IconName;
    title: string;
    description: string;
    tone?: "primary" | "blue" | "purple" | "green" | "orange" | "red";
}

const { icon, title, description, tone = "primary" } = Astro.props;

const cardTones = {
    primary: "from-sky-500/8 to-violet-500/12 border-sky-400/20",
    blue: "from-sky-500/8 to-cyan-500/12 border-sky-400/20",
    purple: "from-violet-500/8 to-fuchsia-500/12 border-violet-400/20",
    green: "from-emerald-500/8 to-teal-500/12 border-emerald-400/20",
    orange: "from-amber-500/8 to-orange-500/12 border-amber-400/20",
    red: "from-rose-500/8 to-red-500/12 border-rose-400/20",
};
---

<Card
    class:list={[
        "bg-gradient-to-br p-6 hover:-translate-y-1 hover:bg-slate-900/90",
        cardTones[tone],
    ]}
>
    <div class="mb-4 flex items-center gap-3">
        <GradientIcon name={icon} size="lg" tone={tone} />
        <h3 class="text-xl font-bold text-white">{title}</h3>
    </div>
    <p class="leading-7 text-slate-400">{description}</p>
</Card>
